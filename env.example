# ========================================
# EasyFolio 环境配置模板
# ========================================
# 【使用说明】
# 1. 复制此文件为 .env（不要提交 .env 到 Git）
# 2. 复制为 .env.development 或 .env.production（按需）
# 3. 根据需要填写实际配置值
# 4. 不要将包含真实密钥的文件提交到代码仓库
# ========================================

# ========================================
# 注意：当前项目（easyfolio-portfolio）是纯静态HTML项目
# 不使用环境变量系统。此配置模板仅作为未来扩展参考。
# ========================================

# ========================================
# Coze API 配置（参考）
# ========================================
# Coze API Key - 在 coze.com 平台获取
# 格式：pat_xxxxxxxxxxxxx
COZE_API_KEY=your_coze_api_key_here

# Coze Bot ID - 在机器人URL中获取
# 格式：73xxxxxxxxxxxxx
COZE_BOT_ID=your_coze_bot_id_here

# Coze API Base URL (可选，默认为官方API)
COZE_API_BASE_URL=https://api.coze.com

# ========================================
# 服务器配置（参考）
# ========================================
# 开发环境服务器端口
PORT=3000

# API Base URL (开发环境使用)
API_BASE_URL=http://localhost:3000

# ========================================
# 应用配置（参考）
# ========================================
# 运行环境：development | production
NODE_ENV=development

# 应用名称
APP_NAME=EasyFolio

# 应用版本
APP_VERSION=1.0.0

