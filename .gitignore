# ========================================
# EasyFolio .gitignore
# ========================================

# 依赖文件夹
node_modules/
.npm/

# 编译输出
dist/
build/

# 临时文件
*.log
.DS_Store
Thumbs.db

# IDE 配置
.vscode/
.idea/
*.swp
*.swo

# ========================================
# 环境变量配置（重要！）
# ========================================
# 包含真实密钥的环境文件
.env
.env.local
.env.*.local

# 生产环境配置（应在部署平台配置）
.env.production

# ========================================
# 其他配置
# ========================================
# 腾讯云配置（包含敏感信息）
.cloudbase/

# Obsidian 相关（这是一个 EasyFolio 项目，不是 Obsidian vault）
.obsidian/
.smtcmp_json_db/

# Trae IDE 内部文档
.trae/

# 前端旧文件夹
frontend/
